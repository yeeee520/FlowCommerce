# ============================================================
# 电商 AI Agent 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# ---- API 密钥 ----
# OpenAI 兼容 API 密钥（必填）
OPENAI_API_KEY=sk-your-key-here

# API 基础地址，默认 OpenAI 官方；可替换为兼容代理
OPENAI_API_BASE=https://api.openai.com/v1

# ---- 模型选择 ----
# 嵌入模型（生成向量用）
EMBEDDING_MODEL=text-embedding-3-small

# 大语言模型（对话/推理用）
LLM_MODEL=gpt-4o-mini

# ---- 数据库路径 ----
# ChromaDB 向量数据库持久化目录
# CHROMA_PERSIST_DIR=./chroma_db

# SQLite 数据库文件路径
# SQLITE_DB_PATH=./data/ecommerce.db

# ---- 文本分块 ----
# 分块大小（字符数）
# CHUNK_SIZE=512

# 相邻块重叠字符数
# CHUNK_OVERLAP=64

# ---- 检索参数 ----
# 向量检索返回文档数量
# TOP_K=5

# ---- 批量处理 ----
# 每批处理数据量
# BATCH_SIZE=100

# 最大重试次数
# MAX_RETRIES=3

# ---- API 服务 ----
# 监听地址
# API_HOST=0.0.0.0

# 监听端口
# API_PORT=8000

# CORS 允许来源（逗号分隔，* 表示全部）
# CORS_ORIGINS=*
